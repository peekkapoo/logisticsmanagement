	journaltitle = {Discover Sustainability},
	shortjournal = {Discover Sustainability},
	author = {Sheikh, Adnan Ahmed and Yousaf, Mohammed Fathi and Alshuaibi, Mohammad Said and Tariq, Beenish and Durrani, Shahrukh and Hameed, Irfan and Raza, Syed Hassan and Yousaf, Muhammad and Badawy, Mamoun},
